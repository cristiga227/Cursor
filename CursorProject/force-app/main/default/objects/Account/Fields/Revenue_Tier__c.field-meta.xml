<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Revenue_Tier__c</fullName>
    <label>Revenue Tier</label>
    <type>Text</type>
    <formula>
        IF(AnnualRevenue >= 1000000, "Gold",
            IF(AnnualRevenue >= 250000, "Silver", "Bronze")
        )
    </formula>
</CustomField>